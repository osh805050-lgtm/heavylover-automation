# .env 템플릿 — 실제 값 채운 뒤 `.env`로 복사
# GitHub에는 이 파일(.env.example)만 커밋. 실제 `.env`는 .gitignore로 제외됨.

# 카페24 API
CAFE24_MALL_ID=
CAFE24_CLIENT_ID=
CAFE24_CLIENT_SECRET=
CAFE24_REDIRECT_URI=https://www.localhost.com
CAFE24_ACCESS_TOKEN=
CAFE24_REFRESH_TOKEN=
CAFE24_AUTH_CODE=

# 네이버 커머스 API
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
SMARTSTORE_EXCEL_PASSWORD=

# 텔레그램 봇
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Meta Marketing API
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
META_API_VERSION=v21.0

# 이메일 발송 (주간 리포트 — Gmail SMTP 권장)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=

# 네이버 API용 프록시 서버 (Vultr)
PROXY_HOST=
PROXY_PORT=
PROXY_USER=
PROXY_PASSWORD=
