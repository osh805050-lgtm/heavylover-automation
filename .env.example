# .env 템플릿 — 실제 값 채운 뒤 `.env`로 복사
# GitHub에는 이 파일(.env.example)만 커밋. 실제 `.env`는 .gitignore로 제외됨.

# 카페24 API
CAFE24_MALL_ID=
CAFE24_CLIENT_ID=
CAFE24_CLIENT_SECRET=
CAFE24_REDIRECT_URI=https://www.localhost.com
CAFE24_ACCESS_TOKEN=
CAFE24_REFRESH_TOKEN=
CAFE24_AUTH_CODE=

# 네이버 커머스 API
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
SMARTSTORE_EXCEL_PASSWORD=

# 텔레그램 봇
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Meta Marketing API
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
META_API_VERSION=v21.0

# 이메일 발송 (주간 리포트 — Gmail SMTP 권장)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=

# 네이버 API용 프록시 서버 (Vultr)
PROXY_HOST=
PROXY_PORT=
PROXY_USER=
PROXY_PASSWORD=

# 네이버 메일 IMAP (정부지원 레이더 — Layer 2 교차검증용)
# - 사전: 네이버 메일 환경설정에서 IMAP 사용 ON + 2단계 인증 + 앱 비밀번호 발급
# - NAVER_MAIL_USER: @naver.com 앞부분만 (예: osh805050)
# - NAVER_MAIL_APP_PASSWORD: 16자리 앱 비밀번호 (일반 비번 ❌)
NAVER_MAIL_USER=
NAVER_MAIL_APP_PASSWORD=

# 공공데이터포털 API (정부지원 레이더 — Layer 1 K-Startup + 기업마당 공식 API)
# - 발급: https://www.data.go.kr → "K-Startup 사업공고" + "기업마당" 활용신청 → 마이페이지에서 Decoding 인증키 복사
# - 가이드: docs/govt-radar/04-public-data-api.md
DATA_GO_KR_API_KEY=

# Google Calendar 자동등록 (정부지원 레이더 — 적합도 ≥ 7 공고 D-7/D-3/마감 등록)
# - 가이드: docs/govt-radar/06-google-calendar-setup.md
# - GOOGLE_SA_KEY_JSON: 서비스 계정 JSON 키 (전체 또는 Base64). 미설정 시 GOOGLE_SA_KEY_PATH 또는 ./gcp-key.json 폴백
# - GOOGLE_CALENDAR_ID: 본사 캘린더 ID (예: abc123@group.calendar.google.com)
# - 미설정 시 캘린더 등록 자동 스킵 (텔레그램 알림은 정상 작동)
GOOGLE_SA_KEY_JSON=
GOOGLE_CALENDAR_ID=

# Gmail 주간 다이제스트 (정부지원 레이더 — 매주 월요일 08:00 KST 자동 발송)
# - 가이드: docs/govt-radar/07-gmail-digest-setup.md
# - SMTP_USER: Gmail 주소 (예: osh805050@gmail.com)
# - SMTP_PASSWORD: Gmail "앱 비밀번호" 16자리 (일반 비밀번호 ❌, 2단계 인증 필요)
# - EMAIL_TO: 수신처 (콤마로 여러 명, 예: ohkm8050@naver.com,osh805050@gmail.com)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=

# 재구매 분석 자동화 (sheets_sync.py + repurchase_report.py)
# - GOOGLE_SA_KEY_PATH: Vultr 기준 절대경로 권장 (예: /root/heavylover-repurchase/gcp-service-account.json)
#   로컬 테스트 시엔 파일을 프로젝트 루트에 두면 자동 폴백됨
# - REPURCHASE_SHEET_ID: 재구매 분석 시트 URL의 /d/ 뒤 ID
# - ANTHROPIC_API_KEY: console.anthropic.com에서 발급 (sk-ant-...)
GOOGLE_SA_KEY_PATH=
REPURCHASE_SHEET_ID=
ANTHROPIC_API_KEY=

# Meta 광고 일별 누적 시트 (메타 광고 자동화 전용)
# - GOOGLE_SHEETS_ID: 새 시트 1장 만들고 URL의 /d/{ID}/edit 부분 입력
# - GOOGLE_SERVICE_ACCOUNT_JSON: 서비스 계정 키 — 다음 중 하나
#     1) 파일 경로 (예: ./gcp-key.json 또는 /root/heavylover-automation/gcp-key.json)
#     2) JSON 원본 ({"type":"service_account",...} 통째로)
#     3) Base64 인코딩된 JSON (GitHub Secrets에서 권장 — 줄바꿈 문제 회피)
# - 서비스 계정 이메일을 해당 시트 공유 권한(편집자)에 추가해야 동작
# - 워크시트 Meta_Ads_Daily / Meta_Ads_Daily_Campaign / Meta_Ads_Winners 자동 생성됨
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=
